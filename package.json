{
  "name": "wec-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter ingestor --filter api --filter app run dev",
    "build": "pnpm -r run build",
    "build:api": "pnpm --filter api run build",
    "build:ingestor": "pnpm --filter ingestor run build",
    "build:app": "pnpm --filter app run build",
    "start": "pnpm --filter api run start",
    "start:api": "pnpm --filter api run start",
    "start:ingestor": "pnpm --filter ingestor run start",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "lint": "oxlint packages/",
    "lint:fix": "oxlint --fix packages/",
    "fmt": "oxfmt packages/",
    "fmt:check": "oxfmt --check packages/"
  },
  "devDependencies": {
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
